{
  "mcpServers": {
    "aas-repo": {
      "command": "aas-mcp-server",
      "args": [
        "--component",
        "aas-repo",
        "--base-url",
        "http://localhost:8080"
      ],
      "env": {
        "LOG_LEVEL": "INFO"
      }
    },
    "submodel-repo": {
      "command": "aas-mcp-server",
      "args": [
        "--component",
        "submodel-repo",
        "--base-url",
        "http://localhost:8081"
      ],
      "env": {
        "LOG_LEVEL": "INFO"
      }
    },
    "aas-registry": {
      "command": "aas-mcp-server",
      "args": [
        "--component",
        "aas-registry",
        "--base-url",
        "http://localhost:8083"
      ],
      "env": {
        "LOG_LEVEL": "INFO"
      }
    },
    "submodel-registry": {
      "command": "aas-mcp-server",
      "args": [
        "--component",
        "submodel-registry",
        "--base-url",
        "http://localhost:8084"
      ],
      "env": {
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
