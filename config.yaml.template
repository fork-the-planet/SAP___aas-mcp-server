# AAS MCP Server Configuration Template
#
# This file shows all configuration options for runtime use and build-time spec generation.
# Copy this file to config.yaml and customize for your setup.
#
# IMPORTANT: You must provide OpenAPI specifications for your components.
# Download official AAS specs from: https://github.com/admin-shell-io/aas-specs
#
# All paths in this file are resolved relative to the config file's directory.

components:
  # ===========================================================================
  # AAS Repository Configuration
  # ===========================================================================
  aas-repo:
    # Official AAS OpenAPI spec (REQUIRED if no implementation_spec)
    # Download from: https://github.com/admin-shell-io/aas-specs
    official_spec: specs/AssetAdministrationShellRepositoryServiceSpecification-V3.1.1_SSP-001.yaml

    # Implementation-specific spec (OPTIONAL)
    # If both official + implementation specs are provided, the server will:
    #   1. Derive intersection (only endpoints your backend supports)
    #   2. Apply overlay if provided
    # implementation_spec: specs/my-backend-aas-repo-endpoints.yaml

    # Overlay for customizing operation names and descriptions (OPTIONAL)
    # overlay: overlays/aas-repo-overlay.yaml

    # Curation settings (OPTIONAL)
    # Controls which operations are exposed and how they're named
    # If omitted, uses hardcoded defaults from tool_curation.py
    curation:
      # Allowlist: Only these path+method combinations will be exposed
      # Supports wildcards:
      #   [get, *]      - All GET operations on any path
      #   [*, /shells]  - All methods on /shells path
      #   [*, *]        - All methods on all paths (use with caution!)
      allowlist:
        - [get, /shells]
        - [post, /shells]
        - [get, /shells/{aasIdentifier}]
        - [put, /shells/{aasIdentifier}]
        - [delete, /shells/{aasIdentifier}]
        # Example wildcard: Allow all GET operations
        # - [get, *]

      # Aliases: Rename operations for better LLM understanding
      aliases:
        GetAllAssetAdministrationShells: list_shells
        PostAssetAdministrationShell: create_shell
        GetAssetAdministrationShellById: get_shell
        PutAssetAdministrationShellById: update_shell
        DeleteAssetAdministrationShellById: delete_shell

  # ===========================================================================
  # Submodel Repository Configuration
  # ===========================================================================
  submodel-repo:
    official_spec: specs/SubmodelRepositoryServiceSpecification-V3.1.1_SSP-001.yaml
    # implementation_spec: specs/my-backend-submodel-repo-endpoints.yaml
    # overlay: overlays/submodel-repo-overlay.yaml

  # ===========================================================================
  # AAS Registry Configuration
  # ===========================================================================
  aas-registry:
    official_spec: specs/AssetAdministrationShellRegistryServiceSpecification-V3.1.1_SSP-001.yaml
    # implementation_spec: specs/my-backend-aas-registry-endpoints.yaml
    # overlay: overlays/aas-registry-overlay.yaml

  # ===========================================================================
  # Submodel Registry Configuration
  # ===========================================================================
  submodel-registry:
    official_spec: specs/SubmodelRegistryServiceSpecification-V3.1.1_SSP-001.yaml
    # implementation_spec: specs/my-backend-submodel-registry-endpoints.yaml
    # overlay: overlays/submodel-registry-overlay.yaml

# =============================================================================
# Path Resolution
# =============================================================================
# All paths are relative to this config file's directory.
#
# Example directory structure:
#   my-project/
#     ├── config.yaml (this file)
#     ├── specs/
#     │   ├── AssetAdministrationShellRepositoryServiceSpecification-V3.1.1_SSP-001.yaml
#     │   └── my-backend-aas-repo-endpoints.yaml
#     └── overlays/
#         └── aas-repo-overlay.yaml
#
# Then use: official_spec: specs/AssetAdministration...yaml
#
# For absolute paths, provide the full path:
#   official_spec: /opt/specs/aas-repo-spec.yaml

# =============================================================================
# Usage
# =============================================================================
#
# Runtime (MCP Server — stdio, for local use without auth):
#   aas-mcp-server --component aas-repo --base-url http://localhost:8080 --config config.yaml
#
# Runtime (MCP Server — HTTP transport with OAuth via OIDCProxy):
#   OAUTH_ISSUER_URL=https://your-idp.example.com/.well-known/openid-configuration \
#   OAUTH_CLIENT_ID=your-client-id \
#   OAUTH_CLIENT_SECRET=your-client-secret \
#   OAUTH_AUDIENCE=your-client-id \
#   OAUTH_SERVER_BASE_URL=http://localhost:8000 \
#   aas-mcp-server --component aas-repo --base-url https://your-backend:8080 \
#                  --transport streamable-http --host 0.0.0.0 --port 8000 \
#                  --config config.yaml
#
# =============================================================================
# MIGRATION NOTICE — Breaking change from RemoteAuthProvider to OIDCProxy
# =============================================================================
#
# If you were using the previous RemoteAuthProvider-based OAuth configuration,
# the following changes are required:
#
#   REMOVED:  OAUTH_JWKS_URI (auto-discovered from OIDC config — remove this var)
#   ADDED:    OAUTH_CLIENT_ID (required — client ID from your IdP app registration)
#   ADDED:    OAUTH_CLIENT_SECRET (required for confidential clients)
#   CHANGED:  OAUTH_ISSUER_URL now accepts either the issuer base URL or the full
#             OIDC configuration URL. Both forms work — the suffix
#             /.well-known/openid-configuration is auto-appended if absent.
#
# Why this change? The previous RemoteAuthProvider implementation required
# IdPs to support Dynamic Client Registration (RFC 7591). Most enterprise IdPs
# (SAP IAS, Azure AD, Google, etc.) do not support DCR. OIDCProxy acts as an
# OAuth Authorization Server itself, proxying the PKCE flow to the upstream IdP
# using pre-registered server-side credentials. This works with any OIDC IdP.
#
# =============================================================================
# Environment Variables — OAuth 2.1 Authorization (HTTP transports only)
# =============================================================================
#
# OAUTH_ISSUER_URL        (Required to enable OAuth)
#   OIDC issuer URL or full OIDC configuration document URL.
#   The /.well-known/openid-configuration suffix is appended automatically
#   if not already present in the value.
#   Examples:
#     SAP IAS:    https://my-tenant.accounts.ondemand.com
#     Keycloak:   https://keycloak.example.com/realms/my-realm
#     Azure AD:   https://login.microsoftonline.com/{tenant-id}/v2.0
#     Okta:       https://my-org.okta.com
#
# OAUTH_CLIENT_ID         (Required when OAUTH_ISSUER_URL is set)
#   Client ID of the application registered at the upstream IdP.
#   This is the MCP server's own client credentials — not the end user's client.
#   The MCP server uses these credentials to proxy the PKCE flow.
#   Example: cf4b45a9-02ba-4f17-ab95-f677b0196afa
#
# OAUTH_CLIENT_SECRET     (Required for confidential clients)
#   Client secret from the IdP app registration.
#   Omit only for PKCE public clients — must then set OAUTH_JWT_SIGNING_KEY.
#
# OAUTH_AUDIENCE          (Recommended)
#   Audience value to forward to the upstream IdP and validate in tokens.
#   For SAP IAS: same as OAUTH_CLIENT_ID (the application UUID).
#   For Azure AD: your API identifier (e.g. api://your-app-id).
#   When not set, audience validation is disabled (not recommended for production).
#
# OAUTH_REQUIRED_SCOPES   (Optional)
#   Comma-separated list of OAuth scopes requested from the upstream IdP during
#   the PKCE authorization flow. The IdP will only authorize users who hold these
#   scopes. Scope enforcement happens at the IdP — not per-request on FastMCP tokens.
#   Example: openid,email,profile
#
# OAUTH_SERVER_BASE_URL   (Required when MCP_HOST is 0.0.0.0 or ::)
#   Public-facing base URL of this server. Used for:
#   - The /auth/callback redirect URI registered with the upstream IdP
#   - OAuth metadata advertised to MCP clients
#   Must match a redirect URI registered in your IdP application.
#   Example: http://localhost:8000  (development)
#            https://mcp.your-domain.com  (production)
#
# OAUTH_JWT_SIGNING_KEY   (Recommended for production)
#   Secret used to sign FastMCP-issued JWT tokens. When not set, FastMCP
#   auto-manages keys (ephemeral on Linux — tokens invalidated on restart).
#   For production, set to a stable secret loaded from a secrets manager.
#
# MCP_RATE_LIMIT_PER_MINUTE  (Optional, default: 60)
#   Maximum MCP tool invocations per authenticated client per minute.
#
# =============================================================================
# Environment Variables — Backend Token Strategy
# =============================================================================
#
# Controls how the MCP server authenticates to the AAS backend API.
#
# BACKEND_AUTH_STRATEGY (Optional, default: forward)
#   Which strategy to use for backend calls:
#     forward        - Forward the upstream user token as-is. Default when
#                      BACKEND_AUTH_AUDIENCE is not set. Works when the
#                      backend accepts the same token the user authenticated
#                      with (same IdP, same audience).
#     token_exchange - RFC 8693 token exchange. Trades the user's upstream
#                      token for a backend-scoped token. Preserves user
#                      identity (sub claim). Auto-selected when
#                      BACKEND_AUTH_AUDIENCE is set.
#     none           - No Authorization header. For public backends or
#                      backends using other auth (e.g. mTLS).
#
# BACKEND_AUTH_AUDIENCE (Optional)
#   OAuth client ID of the AAS backend application. When set, auto-selects
#   token_exchange strategy. The issued token will have aud == this value.
#   Example: -e BACKEND_AUTH_AUDIENCE=my-aas-backend-client-id
#
# BACKEND_AUTH_TOKEN_ENDPOINT (Optional)
#   Full URL of the token endpoint for token exchange.
#   Defaults to <OAUTH_ISSUER_URL>/oauth2/token when not set.
#   Set explicitly for cross-IdP scenarios (user IdP != backend IdP).
#   Example: -e BACKEND_AUTH_TOKEN_ENDPOINT=https://idp.example.com/oauth2/token
#
# BACKEND_AUTH_SCOPE (Optional)
#   Space-separated scopes to request in the token exchange.
#   Example: -e BACKEND_AUTH_SCOPE="aas.read aas.write"
#
# BACKEND_AUTH_CLIENT_ID (Optional, default: OAUTH_CLIENT_ID)
#   Client ID for authenticating the token exchange request.
#   Set only if the MCP server uses a different client for backend token
#   exchange than for user authentication.
#
# BACKEND_AUTH_CLIENT_SECRET (Optional, default: OAUTH_CLIENT_SECRET)
#   Client secret for BACKEND_AUTH_CLIENT_ID.
#
# =============================================================================
# Environment Variables — Server / Transport
# =============================================================================
#
# AAS_BASE_URL             Base URL of the AAS backend (required)
# MCP_TRANSPORT            Transport: stdio (default), http, sse, streamable-http
# MCP_HOST                 Bind host for HTTP transports (default: 127.0.0.1)
# MCP_PORT                 Bind port for HTTP transports (default: 8000)
# AAS_HTTP_TIMEOUT         Backend HTTP timeout in seconds (default: 30)
# AAS_MCP_ENABLE_WRITES=1  Enable POST/PUT/PATCH/DELETE operations
# LOG_LEVEL                Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# CONFIG_PATH              Path to this config file
#
# =============================================================================
# Docker example (SAP IAS, token_exchange for backend):
# =============================================================================
#
#   docker run \
#     -v $(pwd)/config.yaml:/app/config/config.yaml \
#     -v $(pwd)/specs:/app/specs \
#     -e AAS_BASE_URL=https://your-backend:8080 \
#     -e MCP_TRANSPORT=streamable-http \
#     -e MCP_HOST=0.0.0.0 \
#     -e MCP_PORT=8000 \
#     -e OAUTH_ISSUER_URL=https://my-tenant.accounts.ondemand.com \
#     -e OAUTH_CLIENT_ID=cf4b45a9-02ba-4f17-ab95-f677b0196afa \
#     -e OAUTH_CLIENT_SECRET=your-client-secret \
#     -e OAUTH_AUDIENCE=cf4b45a9-02ba-4f17-ab95-f677b0196afa \
#     -e OAUTH_SERVER_BASE_URL=http://localhost:8000 \
#     -e OAUTH_JWT_SIGNING_KEY=your-stable-signing-secret \
#     -e BACKEND_AUTH_AUDIENCE=your-aas-backend-client-id \
#     -p 8000:8000 \
#     aas-mcp-server
#
# BACKEND_AUTH_TOKEN_ENDPOINT defaults to <OAUTH_ISSUER_URL>/oauth2/token.
# Set it explicitly when the backend uses a different IdP.
#
# =============================================================================
# IdP application registration checklist
# =============================================================================
#
# Register the following redirect URI in your IdP application:
#   {OAUTH_SERVER_BASE_URL}/auth/callback
#   Example: http://localhost:8000/auth/callback
#
# The MCP client's loopback redirect URIs (e.g. http://127.0.0.1:9876/callback)
# are handled by the MCP server's /register endpoint — they do NOT need to be
# registered in the upstream IdP.
